# src-tauri/.env — dev-machine-local, gitignored. Copy this file to `.env` in the
# same directory and fill in real values. build.rs reads it and bakes each value in
# at compile time via `cargo:rustc-env` — these are NOT runtime-configurable; a
# rebuild is required after changing them (build.rs sets `cargo:rerun-if-changed=.env`
# so a plain `cargo build`/`npm run tauri dev` picks up edits automatically).

# Google OAuth "Desktop app" type client ID (Google Cloud Console). NOT the same
# client as skillshome-app's web GOOGLE_CLIENT_ID — Desktop-type clients are
# public/PKCE-only (no client secret) and are the only type Google allows to use
# the loopback-redirect exception this app's sign-in flow relies on.
GOOGLE_DESKTOP_CLIENT_ID=your-desktop-client-id.apps.googleusercontent.com

# GitHub OAuth App client ID, with Device Flow enabled in that app's settings.
# Also NOT the same app as skillshome-app's web GitHub OAuth App (that one only
# supports a single callback URL, already used by web login) — this needs its own,
# separate GitHub OAuth App registration.
GITHUB_DEVICE_CLIENT_ID=your-github-device-flow-client-id

# Base URL of the skillshome-app backend this desktop app talks to for
# /api/auth/desktop/token and /api/auth/desktop/refresh. Defaults to
# http://localhost:3000 if unset — only needed here for a non-default target
# (e.g. a staging/production deployment).
SKILLSHOME_BACKEND_URL=http://localhost:3000
