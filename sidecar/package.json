{
  "name": "skillshome-desktop-sidecar",
  "private": true,
  "version": "0.0.0",
  "description": "Local profile extraction via @menporulalar/agents-core, run directly with node/ts-node. Reads the desktop app's real Extraction_Source setting (task 4.9) and, for Local_Model/BYOK_Frontier sources, stages/confirms the result over the real MCP server via the official SDK client (task 4.11). `stage`/`confirm` are the stable script names Rust spawns directly (task 4.12); `extract:sample*` remain for manual CLI use.",
  "scripts": {
    "extract:sample": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/run-local-extraction.ts",
    "extract:sample:stage": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/run-local-extraction-and-stage.ts",
    "stage": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/run-local-extraction-and-stage.ts",
    "confirm": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/confirm-staged-ingestion.ts",
    "test": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/__tests__/resolveExtractionConfig.test.ts && ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/__tests__/mcpClient.test.ts && ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/__tests__/runProjectSync.test.ts",
    "project-sync": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' src/run-project-sync.ts"
  },
  "dependencies": {
    "@menporulalar/agents-core": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}